# ============================================
# IoT Streaming Pipeline - Environment Config
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to Git!
# ============================================

# TimescaleDB
POSTGRES_USER=pipeline_user
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=iot_sensors

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_grafana_password

# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC=sensor-data
KAFKA_DLQ_TOPIC=sensor-data-dlq

# Producer
PRODUCER_DELAY_MS=100
PRODUCER_BATCH_SIZE=10
PRODUCER_ANOMALY_RATE=0.05
PRODUCER_DATA_FILE=/app/data/IOT-temp.csv

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
